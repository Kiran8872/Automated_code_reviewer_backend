# Environment Variables Configuration

# Copy this file to .env and fill in your API keys

# Server Configuration
PORT=5000
NODE_ENV=development

# Comma-separated list of allowed origins in production
# Example: CORS_ORIGIN=https://yourapp.com,https://www.yourapp.com
CORS_ORIGIN=

# API rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# MongoDB connection string
MONGODB_URI=mongodb://127.0.0.1:27017/ai_code_reviewer

# AI API Keys (At least one is required)

# Google Gemini API Key (Recommended)
# Get your key at: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
# Optional model override (default: gemini-2.0-flash)
GEMINI_MODEL=gemini-2.0-flash

# Groq API Key (Alternative)
# Get your key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
# Optional model override (default: llama-3.1-8b-instant)
GROQ_MODEL=llama-3.1-8b-instant

# Note: If both keys are provided, Gemini will be used as primary with Groq as fallback
